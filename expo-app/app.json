{
  "expo": {
    "name": "Zuko",
    "slug": "zuko",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "androidStatusBar": {
      "backgroundColor": "#0b0d12",
      "barStyle": "light-content",
      "translucent": false,
      "hidden": false
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0d12"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zuko.user",
      "infoPlist": {
        "NSCameraUsageDescription": "Zuko needs camera for video calls.",
        "NSMicrophoneUsageDescription": "Zuko needs microphone for calls.",
        "NSPhotoLibraryUsageDescription": "Zuko needs photos for your profile."
      }
    },
    "android": {
      "package": "com.zuko.user",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0d12"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "MODIFY_AUDIO_SETTINGS",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "resize"
    },
    "extra": {
      "lumaWebUrl": "https://luma-user.onrender.com",
      "eas": {
        "projectId": "72436173-8890-4946-ac8e-dea507f20d95"
      }
    },
    "owner": "salman112211",
    "plugins": [
      "expo-system-ui",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
