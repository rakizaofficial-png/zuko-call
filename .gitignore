# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.tools/

# Expo shell
expo-app/node_modules/
expo-app/.expo/
expo-app/.fake-home/
# Native projects are generated by `expo prebuild` — regenerate, don't commit
expo-app/android/
expo-app/ios/
*.apk
expo-app/dist/
CoinCall/
